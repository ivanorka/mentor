NEXT_PUBLIC_API_BASE_URL=http://localhost:8081/api/v1
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Neon pooled connection string. Set this only in .env.local and Netlify, never commit it.
# Neon pooled connection string. Never commit a real value.
DATABASE_URL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Local: http://localhost:3000/api/v1/auth/google/callback
# Netlify: https://YOUR-DOMAIN/api/v1/auth/google/callback
GOOGLE_REDIRECT_URL=http://localhost:3000/api/v1/auth/google/callback
OAUTH_STATE_SECRET=
STRIPE_SECRET_KEY=
# Public base URL used after Stripe Checkout, for example http://localhost:3000
PUBLIC_SITE_URL=http://localhost:3000
# Transactional email (Resend). Do not use a personal Gmail password.
RESEND_API_KEY=
NOTIFICATION_FROM="Gaudeamus Mentor <obavijesti@YOUR-DOMAIN>"
NOTIFICATION_TEAM_EMAIL=ivanxiaomicroatia@gmail.com

# For a local frontend that should use the Netlify Function and the shared
# Neon development database, uncomment this and run: npm run dev:netlify
# NEXT_PUBLIC_API_BASE_URL=/api/v1
